# Database Configuration
POSTGRES_URI=postgresql://user:password@host:port/db

# MDB Configuration
# For Windows (Production): {Microsoft Access Driver (*.mdb, *.accdb)}
# For Linux (Development): {MDBTools} (requires sudo apt install odbc-mdbtools)
MDB_PATH=C:\Path\To\Your\Billing.mdb
MDB_DRIVER={Microsoft Access Driver (*.mdb, *.accdb)}

# Sync Configuration
SYNC_INTERVAL_SECONDS=3600
RECONCILIATION_WINDOW_ROWS=5000
SOURCE_SYSTEM=BILLING_MDB

# Logging
LOG_LEVEL=info
